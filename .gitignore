# --- Terraform ---
# Local subdirectory generated by 'terraform init' (contains plugins/binaries)
.terraform/

# Terraform state files (contains sensitive infrastructure data and secrets!)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform plan output (optional)
*.tfplan

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.env
venv/
.venv/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/